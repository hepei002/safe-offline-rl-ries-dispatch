# Raw and intermediate third-party data
# Keep small metadata/README files, but do not commit downloaded raw tables/zips.
data/raw/**
!data/raw/**/
!data/raw/**/README.md
!data/raw/**/datapackage.json
data/interim/**
data/offline/

# Stale/private manuscript workflow drafts; keep the canonical LaTeX source public.
manuscript/applied_energy_safe_offline_rl_draft.md
manuscript/cover_letter_applied_energy.md
manuscript/submission_materials_applied_energy.md

# Large/generated outputs
outputs/
results/figures/**/*.tiff
results/figures/**/*.tif

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.orig
