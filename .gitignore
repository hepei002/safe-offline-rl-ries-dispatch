node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# LaTeX build products
manuscript/latex/build*/
manuscript/latex/*.aux
manuscript/latex/*.bbl
manuscript/latex/*.blg
manuscript/latex/*.fdb_latexmk
